PORT=5000
NODE_ENV=development

# MongoDB connection string
# Local:  mongodb://localhost:27017/easyaccomod
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/easyaccomod
MONGODB_URI=mongodb://localhost:27017/easyaccomod

# JWT secret – đổi thành chuỗi ngẫu nhiên dài trong production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS – domain của frontend
CLIENT_URL=http://localhost:5173
